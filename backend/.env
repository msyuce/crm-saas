# Uygulama Ayarları
APP_NAME=CRM SaaS
APP_ENV=development
APP_DEBUG=True

# Veritabanı Bağlantısı (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://kullanici:parola@localhost:5432/saasdb

# Dil Ayarları
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,tr,bg

# Güvenlik
APP_SECRET_KEY=süper-gizli-anahtar-buraya

# E-Posta Ayarları
EMAIL_HOST=smtp.mailserver.com
EMAIL_PORT=587
EMAIL_USER=your-email@mail.com
EMAIL_PASSWORD=your-email-password

# Redis (opsiyonel)
REDIS_URL=redis://localhost:6379/0

